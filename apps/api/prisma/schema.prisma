// path: apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum CourseStatus {
  passed
  failed
  retaken
  in_progress
  unknown
  absent_final
  banned_final
}

enum SectionType {
  LEC
  LAB
  OTHER
}

enum UserRole {
  user
  admin
}

enum SchoolType {
  university
  college
  highschool
  other
}

enum ExamPlanType {
  tentative
  official
}

enum ExamParseStatus {
  parsed
  partial
  failed
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      UserRole @default(user)

  schoolType   SchoolType @default(university)
  birthDate    DateTime
  placeOfBirth String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings    UserSettings?
  imports     ImportSession[]

  transcripts Transcript[]
  timetables  Timetable[]
  sections    ClassSection[]
  evaluations EvaluationDraft[]

  examNotices ExamNotice[]
  examRecords ExamRecord[]
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique

  theme               String   @default("system")
  language            String   @default("vi")
  density             String   @default("comfortable")

  emailAlerts         Boolean  @default(true)
  webPush             Boolean  @default(false)
  timetableReminders  Boolean  @default(true)
  deadlineReminders   Boolean  @default(true)
  gradeAlerts         Boolean  @default(true)
  weeklySummary       Boolean  @default(false)

  rememberDevice      Boolean  @default(true)
  analyticsOptIn      Boolean  @default(false)

  onboardingDismissed Boolean  @default(false)
  lastManualSyncAt    DateTime?
  lastExportAt        DateTime?

  avatarDataUrl       String?  @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImportSession {
  id             String       @id @default(cuid())
  userId         String
  adapterKey     String
  adapterVersion String
  sourcePage     String
  status         ImportStatus @default(SUCCESS)

  payloadHash    String

  recordCounts   Json?
  diffSummary    Json?

  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  transcripts    Transcript[]
  timetables     Timetable[]
  sections       ClassSection[]
  evaluations    EvaluationDraft[]
  examNotices    ExamNotice[]
  examRecords    ExamRecord[]

  @@unique([userId, adapterKey, adapterVersion, payloadHash], name: "uq_importsession_idempotent")
  @@index([userId, startedAt])
  @@index([adapterKey, adapterVersion])
}

model Transcript {
  id          String       @id @default(cuid())
  userId      String
  importId    String?

  courseCode  String
  courseName  String
  credits     Int

  score10     Float?
  letter      String?
  gpa4        Float?

  semester    String
  status      CourseStatus @default(unknown)

  componentsBreakdown Json?

  adapterKey     String
  adapterVersion String
  sourcePage     String
  lastSyncedAt   DateTime @default(now())

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import      ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, courseCode, semester], name: "uq_transcript_natural")
  @@index([userId, semester])
  @@index([courseCode])
}

model Timetable {
  id              String   @id @default(cuid())
  userId          String
  importId        String?

  semester        String
  weekLabel       String?
  weekStartDate   DateTime?
  weekEndDate     DateTime?
  occurrenceDate  DateTime

  courseCode      String
  courseName      String?

  dayOfWeek       Int
  startTime       String
  endTime         String
  room            String
  campus          String?

  weeksIncluded   String?
  weeksCanceled   String?

  adapterKey      String
  adapterVersion  String
  sourcePage      String
  lastSyncedAt    DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, occurrenceDate, courseCode, startTime, room], name: "uq_timetable_occurrence")
  @@index([userId, occurrenceDate])
  @@index([userId, semester])
}

model ClassSection {
  id             String      @id @default(cuid())
  userId         String
  importId       String?

  semester       String
  classCode      String
  courseCode     String
  credits        Int
  type           SectionType @default(OTHER)

  capacityStatus String
  note           String?

  scheduleSlots  Json?
  weeksIncluded  String?
  weeksCanceled  String?

  adapterKey     String
  adapterVersion String
  sourcePage     String
  lastSyncedAt   DateTime @default(now())

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import         ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, semester, classCode], name: "uq_section_natural")
  @@index([userId, semester])
}

model EvaluationDraft {
  id             String @id @default(cuid())
  userId         String
  importId       String?

  semester       String
  lecturer       String
  courseCode     String
  courseName     String?

  answers        Json

  adapterKey     String
  adapterVersion String
  sourcePage     String
  lastSyncedAt   DateTime @default(now())

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import         ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([userId, semester])
}

model ExamNotice {
  id               String          @id @default(cuid())
  userId           String
  importId         String?

  planType         ExamPlanType    @default(official)
  parseStatus      ExamParseStatus @default(parsed)

  title            String
  rawTitle         String?
  sourceText       String?         @db.Text
  courseCodeHint   String?
  courseNameHint   String?

  detailUrl        String
  attachmentUrl    String?
  attachmentName   String?

  publishedAtRaw   String?
  publishedAt      DateTime?

  sourcePage       String
  adapterKey       String
  adapterVersion   String

  noticeHash       String
  isLatest         Boolean         @default(true)
  isSuperseded     Boolean         @default(false)
  supersededAt     DateTime?
  supersededReason String?

  detailText       String?         @db.Text
  parseError       String?         @db.Text
  lastSyncedAt     DateTime        @default(now())

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  import           ImportSession?  @relation(fields: [importId], references: [id], onDelete: SetNull)

  records          ExamRecord[]

  @@unique([userId, noticeHash], name: "uq_exam_notice_hash")
  @@unique([userId, detailUrl], name: "uq_exam_notice_detail")
  @@index([userId, planType, isLatest])
  @@index([userId, publishedAt])
  @@index([userId, title])
  @@index([userId, courseCodeHint])
}

model ExamRecord {
  id               String          @id @default(cuid())
  userId           String
  importId         String?
  noticeId         String?

  planType         ExamPlanType    @default(official)
  parseStatus      ExamParseStatus @default(parsed)

  noticeTitle      String
  publishedAtRaw   String?
  publishedAtDate  DateTime?

  detailUrl        String
  attachmentUrl    String?
  attachmentName   String?

  courseCode       String
  courseName       String?

  examDate         DateTime?
  examDateRaw      String?
  startTime        String?
  endTime          String?

  room             String?
  campus           String?
  examMetaRaw      String?         @db.Text

  studentId        String?
  studentName      String?
  classCourse      String?
  classStudent     String?
  birthDateRaw     String?
  birthDate        DateTime?
  note             String?

  recordHash       String
  rawRow           Json?

  isLatest         Boolean         @default(true)
  isSuperseded     Boolean         @default(false)
  supersededAt     DateTime?
  supersededReason String?

  sourcePage       String
  adapterKey       String
  adapterVersion   String
  parseError       String?         @db.Text
  lastSyncedAt     DateTime        @default(now())

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  import           ImportSession?  @relation(fields: [importId], references: [id], onDelete: SetNull)
  notice           ExamNotice?     @relation(fields: [noticeId], references: [id], onDelete: SetNull)

  @@unique([userId, recordHash], name: "uq_exam_record_hash")
  @@index([userId, planType, examDate])
  @@index([userId, courseCode])
  @@index([userId, studentId])
  @@index([userId, studentName])
  @@index([userId, examDate])
  @@index([userId, isLatest, isSuperseded])
  @@index([noticeId])
}