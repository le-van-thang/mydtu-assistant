generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum CourseStatus {
  passed
  failed
  retaken
  in_progress
  unknown
  absent_final
  banned_final
}

enum SectionType {
  LEC
  LAB
  OTHER
}

enum UserRole {
  user
  admin
}

enum SchoolType {
  university
  college
  highschool
  other
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      UserRole @default(user)

  schoolType   SchoolType @default(university)
  birthDate    DateTime
  placeOfBirth String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings    UserSettings?
  imports     ImportSession[]
  transcripts Transcript[]
  timetables  Timetable[]
  sections    ClassSection[]
  evaluations EvaluationDraft[]
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique

  theme               String   @default("system")
  language            String   @default("vi")
  density             String   @default("comfortable")

  emailAlerts         Boolean  @default(true)
  webPush             Boolean  @default(false)
  timetableReminders  Boolean  @default(true)
  deadlineReminders   Boolean  @default(true)
  gradeAlerts         Boolean  @default(true)
  weeklySummary       Boolean  @default(false)

  rememberDevice      Boolean  @default(true)
  analyticsOptIn      Boolean  @default(false)

  onboardingDismissed Boolean  @default(false)
  lastManualSyncAt    DateTime?
  lastExportAt        DateTime?

  avatarDataUrl       String?  @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImportSession {
  id             String       @id @default(cuid())
  userId         String
  adapterKey     String
  adapterVersion String
  sourcePage     String
  status         ImportStatus @default(SUCCESS)

  payloadHash    String

  recordCounts   Json?
  diffSummary    Json?

  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  transcripts    Transcript[]
  timetables     Timetable[]
  sections       ClassSection[]
  evaluations    EvaluationDraft[]

  @@unique([userId, adapterKey, adapterVersion, payloadHash], name: "uq_importsession_idempotent")
  @@index([userId, startedAt])
  @@index([adapterKey, adapterVersion])
}

model Transcript {
  id          String       @id @default(cuid())
  userId      String
  importId    String?

  courseCode  String
  courseName  String
  credits     Int

  score10     Float?
  letter      String?
  gpa4        Float?

  semester    String
  status      CourseStatus @default(unknown)

  componentsBreakdown Json?

  adapterKey     String
  adapterVersion String
  sourcePage     String
  lastSyncedAt   DateTime @default(now())

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import      ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, courseCode, semester], name: "uq_transcript_natural")
  @@index([userId, semester])
  @@index([courseCode])
}

model Timetable {
  id              String   @id @default(cuid())
  userId          String
  importId        String?

  semester        String
  weekLabel       String?
  weekStartDate   DateTime?
  weekEndDate     DateTime?
  occurrenceDate  DateTime

  courseCode      String
  courseName      String?

  dayOfWeek       Int
  startTime       String
  endTime         String
  room            String
  campus          String?

  weeksIncluded   String?
  weeksCanceled   String?

  adapterKey      String
  adapterVersion  String
  sourcePage      String
  lastSyncedAt    DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, occurrenceDate, courseCode, startTime, room], name: "uq_timetable_occurrence")
  @@index([userId, occurrenceDate])
  @@index([userId, semester])
}

model ClassSection {
  id            String      @id @default(cuid())
  userId        String
  importId      String?

  semester      String
  classCode     String
  courseCode    String
  credits       Int
  type          SectionType @default(OTHER)

  capacityStatus String
  note          String?

  scheduleSlots Json?
  weeksIncluded String?
  weeksCanceled String?

  adapterKey     String
  adapterVersion String
  sourcePage     String
  lastSyncedAt   DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import        ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, semester, classCode], name: "uq_section_natural")
  @@index([userId, semester])
}

model EvaluationDraft {
  id          String @id @default(cuid())
  userId      String
  importId    String?

  semester    String
  lecturer    String
  courseCode  String
  courseName  String?

  answers     Json

  adapterKey     String
  adapterVersion String
  sourcePage     String
  lastSyncedAt   DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  import      ImportSession? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([userId, semester])
}